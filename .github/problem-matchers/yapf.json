{
  "problemMatcher": [
    {
      "owner": "yapf-diff",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^--- (\\S+)\\s+\\(original\\)$",
          "file": 1
        },
        {
          "regexp": "^\\+\\+\\+ (\\S+)\\s+\\((.*)\\)$"
         },
        {
          "regexp": "^@@\\s*-(\\d+)(?:,\\d+)?\\s*\\+(\\d+)(?:,\\d+)?\\s*@@$",
          "line": 1,
          "message": 0,
          "loop": true
        }
      ]
    }
  ]
}
