{
  "problemMatcher": [
    {
      "owner": "yapf-diff",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^--- (\\S+)\\s+\\(original\\)$",
          "file": 1
        },
        {
          "regexp": "^\\+\\+\\+ (\\S+)\\s+\\((.*)\\)$",
          "message": 2
         },
        {
          "regexp": "^@@\\s*-(\\d+)(?:,\\d+)?\\s*\\+(\\d+)(?:,\\d+)?\\s*@@\\s*(.*)$",
          "line": 1
        }
      ]
    }
  ]
}
